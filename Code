class Chicken:
    def __init__(self, model, name, color, is_player, clips, is_actor, gz, facing_offset=0):
        self.model, self.name, self.color = model, name, color
        self.is_player, self.clips, self.is_actor = is_player, clips, is_actor
        self.ground_z, self.facing_offset = gz, facing_offset
        self.score = 0; self.xy = np.zeros(2); self.vel = np.zeros(2)
        self.jumping = self.moving = self.anim_locked = False
        self.walk_time = 0.0; self.playing = None; self.leg_l = self.leg_r = None
        self.idle_clip  = pick_idle(clips) or "Idle"
        self.idle_timer = random.uniform(4.0, 9.0)
        if not is_player:
            self.base_speed   = random.uniform(AI_MIN_SPD, AI_MAX_SPD)
            self.speed        = self.base_speed
            self.target_xy    = np.array(rand_world())
            self.claimed_egg  = None
            self.wander_angle = random.uniform(0, 360)
            self.wander_timer = random.uniform(0.3, 1.0)
            self.pause_timer  = self.wobble_time = self.sprint_timer = 0.0
            self.sprint_mult  = 1.0
            self.reaction_lag = random.uniform(0.06, 0.16)
            self.lag_timer    = 0.0

    def play_clip(self, want, loop=True):
        if self.is_actor:
            r = play_anim(self.model, self.clips, want, loop)
            if r: self.playing = r


