class GameTimer:
    _BG        = (0.06, 0.06, 0.08, 0.97)
    _CAPSULE   = (0.10, 0.10, 0.13, 1.00)
    _BORDER_HI = (0.95, 0.85, 0.10, 1.00)
    _BORDER_LO = (0.28, 0.24, 0.04, 1.00)
    _BAR_FULL  = (0.95, 0.85, 0.10, 1.00)
    _BAR_MID   = (0.95, 0.55, 0.10, 1.00)
    _BAR_LOW   = (0.88, 0.16, 0.10, 1.00)
    _BAR_EMPTY = (0.13, 0.13, 0.17, 1.00)
    _GHOST     = (0.18, 0.16, 0.06, 1.00)
    _TXT_NORM  = (1.00, 1.00, 1.00, 1.00)
    _TXT_WARN  = (1.00, 0.72, 0.18, 1.00)
    _TXT_URG   = (1.00, 0.26, 0.12, 1.00)
    _CORNER    = (0.95, 0.85, 0.10, 1.00)
    _W, _H, _BRD, _SEGS = 0.285, 0.155, 0.005, 12
    _SEG_H, _SEG_G      = 0.013, 0.004
    _AX, _AY            = 1.285, 0.870

    def __init__(self, parent, total_secs, font, font_ui, on_expire, font_digital=None):
        self.total_secs = self.time_left = float(total_secs)
        self.font_digital = font_digital or font
        self.on_expire    = on_expire
        self._expired = self._colon_vis = False
        self._last_sec = -1; self._colon_acc = 0.0
        self._colon_vis = True

        W, H, BRD = self._W, self._H, self._BRD
        ax, ay    = self._AX, self._AY
        strip_bot = -H - BRD - self._SEG_H - 0.004

        self._root = DirectFrame(parent=parent, frameColor=(0,0,0,0),
            frameSize=(-W-BRD, W+BRD, strip_bot, H+BRD+0.004), pos=(ax, 0, ay))

        # Border edges
        DirectFrame(parent=self._root, frameColor=self._BORDER_HI,
                    frameSize=(-W-BRD, W+BRD, H, H+BRD))
        for fs, clr in [
            ((-W-BRD, W+BRD, -H-BRD, -H), self._BORDER_LO),
            ((-W-BRD, -W, -H, H),          self._BORDER_LO),
            ((W, W+BRD, -H, H),            self._BORDER_LO),
            ((-W, W, -H, H),               self._BG),
        ]:
            DirectFrame(parent=self._root, frameColor=clr, frameSize=fs)

        # Corner L-bracket accents
        cw, ch, ct = 0.042, 0.030, 0.005
        for bx, by, sx, sy in ((-W, H, 1,-1), (W, H,-1,-1), (-W,-H, 1, 1), (W,-H,-1, 1)):
            DirectFrame(parent=self._root, frameColor=self._CORNER,
                        frameSize=(0, sx*cw, 0, sy*ct), pos=(bx,0,by))
            DirectFrame(parent=self._root, frameColor=self._CORNER,
                        frameSize=(0, sx*ct, 0, sy*ch), pos=(bx,0,by))

        # Capsule label row
        cap_y = H * 0.52
        DirectFrame(parent=self._root, frameColor=self._CAPSULE,
                    frameSize=(-W*0.82, W*0.82, -0.026, 0.026), pos=(0,0,cap_y))
        for dx in (-W*0.68, W*0.68):
            DirectFrame(parent=self._root, frameColor=self._BORDER_HI,
                        frameSize=(-0.010, 0.010, -0.010, 0.010), pos=(dx, 0, cap_y))
        OnscreenText(text="TIME  REMAIN", parent=self._root,
                     pos=(0, cap_y-0.011), scale=0.030, fg=(1,1,1,1),
                     align=TextNode.ACenter, font=font or font_ui, mayChange=False)

        # timer
        OnscreenText(text="88:88", parent=self._root, pos=(0, -H*0.08),
                     scale=0.108, fg=self._GHOST, align=TextNode.ACenter,
                     font=self.font_digital, mayChange=False)
        self._time_text = OnscreenText(
            text=self._fmt(self.total_secs), parent=self._root, pos=(0, -H*0.08),
            scale=0.108, fg=self._TXT_NORM, align=TextNode.ACenter,
            font=self.font_digital, mayChange=True)

        DirectFrame(parent=self._root, frameColor=(0.22,0.20,0.08,0.55),
                    frameSize=(-W*0.82, W*0.82, -0.003, 0), pos=(0,0,-H*0.72))

        # Segmented progress strip
        seg_w  = (2*W - (self._SEGS-1)*self._SEG_G) / self._SEGS
        strip_y = -H - BRD - self._SEG_H - 0.002
        self._seg_fills = []
        for i in range(self._SEGS):
            lx = -W + i*(seg_w + self._SEG_G); rx = lx + seg_w
            DirectFrame(parent=self._root, frameColor=self._BAR_EMPTY,
                        frameSize=(lx, rx, 0, self._SEG_H), pos=(0,0,strip_y))
            fill = DirectFrame(parent=self._root, frameColor=self._BAR_FULL,
                               frameSize=(lx, rx, 0, self._SEG_H), pos=(0,0,strip_y))
            self._seg_fills.append((fill, lx, rx))

    def update(self, dt: float, active: bool) -> None:
        if not active or self._expired:
            return
        self.time_left = max(0.0, self.time_left - dt)
        cur_sec = int(math.ceil(self.time_left))

        self._colon_acc += dt
        if self._colon_acc >= 0.5:
            self._colon_acc -= 0.5
            self._colon_vis = not self._colon_vis

        if cur_sec != self._last_sec:
            self._last_sec = cur_sec
            sep = ":" if self._colon_vis else " "
            m, s = cur_sec // 60, cur_sec % 60
            self._time_text.setText(f"{m:02d}{sep}{s:02d}")
            clr = (self._TXT_URG  if self.time_left <= 10.0 else
                   self._TXT_WARN if self.time_left <= 30.0 else self._TXT_NORM)
            self._time_text.setFg(clr)

        frac = self.time_left / self.total_secs if self.total_secs > 0 else 0.0
        lit  = int(round(frac * self._SEGS))
        bar_clr = (self._BAR_LOW  if self.time_left <= 10.0 else
                   self._BAR_MID  if self.time_left <= 30.0 else self._BAR_FULL)
        for idx, (fill, lx, rx) in enumerate(self._seg_fills):
            fill["frameColor"] = bar_clr
            fill["frameSize"]  = (lx, rx, 0, self._SEG_H) if idx < lit else (lx, lx, 0, self._SEG_H)

        if self.time_left <= 0 and not self._expired:
            self._expired = True
            self._time_text.setText("00:00")
            if callable(self.on_expire):
                self.on_expire()

    def reset(self, total_secs: float = None) -> None:
        if total_secs is not None:
            self.total_secs = float(total_secs)
        self.time_left = self.total_secs
        self._expired = False; self._last_sec = -1
        self._colon_acc = 0.0; self._colon_vis = True
        self._time_text.setText(self._fmt(self.total_secs))
        self._time_text.setFg(self._TXT_NORM)
        for fill, lx, rx in self._seg_fills:
            fill["frameColor"] = self._BAR_FULL
            fill["frameSize"]  = (lx, rx, 0, self._SEG_H)

    def show(self):    self._root.show()
    def hide(self):    self._root.hide()
    def destroy(self):
        try: self._root.destroy()
        except Exception: pass

    @staticmethod
    def _fmt(seconds: float) -> str:
        s = int(math.ceil(seconds))
        return f"{s//60:02d}:{s%60:02d}"


