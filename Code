def _try_download_font(filename, url):
    dest = os.path.join(os.path.dirname(os.path.abspath(__file__)), filename)
    if os.path.exists(dest):
        return True
    try:
        import urllib.request
        print(f"Downloading font: {filename} ...")
        urllib.request.urlretrieve(url, dest)
        return True
    except Exception as e:
        print(f"Font download failed ({filename}): {e}")
        return False

def find_font(app, *names):
    script_dir = os.path.dirname(os.path.abspath(__file__))
    dirs = [script_dir, ".", "fonts", "assets/fonts",
            "/usr/share/fonts", "/usr/share/fonts/truetype", "/usr/share/fonts/opentype",
            "/usr/local/share/fonts", os.path.expanduser("~/.fonts"),
            os.path.expanduser("~/.local/share/fonts"),
            "C:/Windows/Fonts", "/Library/Fonts", "/System/Library/Fonts",
            os.path.expanduser("~/Library/Fonts")]
    for name in names:
        for d in dirs:
            for path in [os.path.join(d, name)] + (
                    [os.path.join(d, sub, name) for sub in os.listdir(d)]
                    if os.path.isdir(d) else []):
                if os.path.exists(path):
                    try: return app.loader.loadFont(path)
                    except: pass

def load_model(loader, *paths):
    for p in paths:
        try: return loader.loadModel(p)
        except: pass

def load_actor(path):
    try:
        a = Actor(path); clips = a.getAnimNames()
        print(f"Actor: {path}  clips={clips}")
        return a, clips, True
    except Exception as e:
        print(f"Actor failed ({path}): {e}")
        return None, [], False

def anim_variants(name):
    return (name, name.capitalize(), name.upper(),
            f"Armature|{name}", f"Armature|{name.capitalize()}")

def play_anim(actor, clips, name, loop=True):
    for v in anim_variants(name):
        if v in clips:
            actor.loop(v) if loop else actor.play(v)
            return v

def hpr_seq(node, spd, *hprs):
    return Sequence(*[LerpHprInterval(node, spd, h) for h in hprs])

def rand_world():
    return (random.uniform(WL+2, WR-2), random.uniform(WB+2, WT-2))

def pick_clip(clips, *order):
    for c in order:
        if c in clips: return c
    return clips[0] if clips else None

pick_idle = lambda c: pick_clip(c, "Idle", "Idle1", "Standing", "Idle2")
pick_walk = lambda c: pick_clip(c, "Walking", "Walk", "walking", "Run", "run")


